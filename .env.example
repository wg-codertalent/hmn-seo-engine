# Required
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Optional — enables Google Sheets backend.
# Without these, the engine falls back to data/*.json files.
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_SHEET_ID=

# Optional — target a separate blog repo via the GitHub API.
# Leave blank to write directly to the parent repo on disk.
BLOG_REPO_OWNER=
BLOG_REPO_NAME=
BLOG_REPO_TOKEN=
BLOG_REPO_BRANCH=main

# Optional — override default paths (relative to the blog repo root)
ARTICLES_DIR=content/articles
IMAGES_DIR=public/images/uploads
CATEGORIES_DIR=content/categories
